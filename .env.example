# Sandesha environment variables
# Copy to .env and fill in values. Never commit .env to git.

# Required before exposing API via Cloudflare Tunnel
SANDESHA_ADMIN_PASSWORD=

# Local dev only — disables API auth (do NOT use with tunnel/public access)
# SANDESHA_AUTH_DISABLED=1

# Optional — Puppeteer / Chromium (see RASPBERRY_PI_SETUP.md)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
